<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="700.0" stylesheets="@../styles/login.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.team3HxD.controller.LoginController">
   <children>
      <VBox styleClass="login-container" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Label styleClass="title-label" text="ĐĂNG NHẬP HỆ THỐNG" />
            <TextField fx:id="usernameField" promptText="Tên đăng nhập" styleClass="input-field" />
            <PasswordField fx:id="passwordField" promptText="Mật khẩu" styleClass="input-field" />
            <Button fx:id="loginButton" onAction="#handleLogin" styleClass="login-button" text="ĐĂNG NHẬP" />
            <Button fx:id="registerButton" onAction="#handleRegister" styleClass="register-button" text="Chưa có tài khoản? Đăng ký ngay" />
         </children>
      </VBox>
   </children>
</AnchorPane>
